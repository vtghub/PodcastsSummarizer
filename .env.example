# Copy this to .env and fill in your values.
# Only GEMINI_API_KEY and Gmail settings are needed for the default local setup.

# ---------------------------------------------------------------------------
# Provider selection (change these to switch implementations)
# ---------------------------------------------------------------------------
TRANSCRIPTION_PROVIDER=local_whisper      # local_whisper | openai_whisper_api
LLM_PROVIDER=gemini                       # gemini | ollama | openai | anthropic
STORAGE_PROVIDER=sqlite                   # sqlite | supabase | postgres
EMAIL_PROVIDER=console                    # console (dev) | gmail_smtp | resend

# ---------------------------------------------------------------------------
# Paths (SQLite / local mode)
# ---------------------------------------------------------------------------
DATA_DIR=./data
SQLITE_DB_FILE=podcasts.db

# ---------------------------------------------------------------------------
# Supabase (cloud storage — set STORAGE_PROVIDER=supabase to activate)
# Dashboard → Project Settings → Database  →  Connection string (Transaction pooler)
# Dashboard → Project Settings → API       →  service_role key
# ---------------------------------------------------------------------------
#SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.mygigptehwsmhqaoydla:[PodcastsSummarizer]@aws-1-us-east-2.pooler.supabase.com:6543/postgres
#SUPABASE_URL=https://[ref].supabase.co
SUPABASE_URL=https://mygigptehwsmhqaoydla.supabase.co
#SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im15Z2lncHRlaHdzbWhxYW95ZGxhIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzIxMTE1OCwiZXhwIjoyMDk4Nzg3MTU4fQ.yEBO4elLhHBZlyTGmsVg6LIhu5NUH6Vx_E044MRppwI

# ---------------------------------------------------------------------------
# Whisper local model
# ---------------------------------------------------------------------------
WHISPER_MODEL=base                        # tiny | base | small | medium | large

# ---------------------------------------------------------------------------
# Gemini (free tier — get key at aistudio.google.com)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSyBg1KF5X1OlzKuNSQH9DsI1LN2jYcyQGrM

# ---------------------------------------------------------------------------
# Ollama (alternative to Gemini — fully local)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Gmail SMTP (for email digest)
# Create an App Password at myaccount.google.com/apppasswords
# ---------------------------------------------------------------------------
GMAIL_SENDER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DIGEST_RECIPIENT=REDACTED_EMAIL

# ---------------------------------------------------------------------------
# Dashboard auth (My Podcasts page)
# Set a strong random string — anyone with this passcode can manage sources
# Also add this to Vercel → Settings → Environment Variables
# ---------------------------------------------------------------------------
ADMIN_SECRET=change-me-to-a-strong-secret

# ---------------------------------------------------------------------------
# Schedule (24-hour format)
# ---------------------------------------------------------------------------
DIGEST_HOUR=7
DIGEST_MINUTE=0

# Copy this to .env and fill in your values.
# Only GEMINI_API_KEY and Gmail settings are needed for the default local setup.

# ---------------------------------------------------------------------------
# Provider selection (change these to switch implementations)
# ---------------------------------------------------------------------------
TRANSCRIPTION_PROVIDER=local_whisper      # local_whisper | openai_whisper_api
LLM_PROVIDER=gemini                       # gemini | ollama | openai | anthropic
STORAGE_PROVIDER=sqlite                   # sqlite | supabase | postgres
EMAIL_PROVIDER=console                    # console (dev) | gmail_smtp | resend

# ---------------------------------------------------------------------------
# Paths (SQLite / local mode)
# ---------------------------------------------------------------------------
DATA_DIR=./data
SQLITE_DB_FILE=podcasts.db

# ---------------------------------------------------------------------------
# Supabase (cloud storage + auth — set STORAGE_PROVIDER=supabase to activate)
# Dashboard → Project Settings → Database  →  Connection string (Transaction pooler)
# Dashboard → Project Settings → API       →  Project URL, anon key, service_role key
# ---------------------------------------------------------------------------
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# These two are safe to expose to the browser (anon key has RLS applied).
# Required for Supabase Auth (email+password login, session cookies).
# Also add both to Vercel → Settings → Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# ---------------------------------------------------------------------------
# Whisper local model
# ---------------------------------------------------------------------------
WHISPER_MODEL=base                        # tiny | base | small | medium | large

# ---------------------------------------------------------------------------
# Gemini (free tier — get key at aistudio.google.com)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------------
# Groq (free-tier fallback LLM — get key at console.groq.com)
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ---------------------------------------------------------------------------
# Ollama (alternative to Gemini — fully local)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Gmail SMTP (for email digest)
# Create an App Password at myaccount.google.com/apppasswords
# ---------------------------------------------------------------------------
GMAIL_SENDER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DIGEST_RECIPIENT=your@gmail.com

# ---------------------------------------------------------------------------
# Dashboard auth (replaced by Supabase Auth in multi-user mode)
# ADMIN_SECRET is no longer used — remove it from Vercel after running
# supabase/migrations/002_multi_user.sql and registering your admin account.
# ---------------------------------------------------------------------------
# ADMIN_SECRET=change-me-to-a-strong-secret  # deprecated

# ---------------------------------------------------------------------------
# Schedule (24-hour format)
# ---------------------------------------------------------------------------
DIGEST_HOUR=19
DIGEST_MINUTE=0
